
<h1>Books</h1>
<%= @books.each do |book| %>
  <p>title</p>
  <span><%= @book.title %></span>
  <p>body</p>
  <span><%= @book.body %></span>
<% end %>

<h2>New book</h2>
<% if @books.errors.any? %>
  <%= @books.errors.count %>errors prohibited this book from being saved:
  <ul>
    <% @books.errors.full_messages.each do |message| %>
      <li><%= message %></li>
    <% end %>
  </ul>
<% end %>

<%= form_with model: @books do |f| %>
  <h4>title</h4>
  <%= f.text_field :title %>
  <h4>body</h4>
  <%= f.text_area :body %>
  <%= f.submit 'Create Book' %>
<% end %>
